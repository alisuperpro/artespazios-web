---
import { Image } from "astro:assets"
import logo from "../assets/logo.png"
const currentYear = new Date().getFullYear()
---

<footer class="py-12 border-t border-beige text-center bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <a
      href="/"
      class="flex items-center justify-center transition-opacity hover:opacity-80"
    >
      <Image
        src={logo}
        alt="Miami Transformation Logo"
        class="w-32 md:w-40 h-auto object-contain"
        loading="eager"
      />
    </a>

    <!-- Información de contacto -->
    <p class="text-xs text-piedra/50 mb-6">
      hola@artespazios.com | Miami & Worldwide
    </p>

    <!-- Enlaces legales -->
    <div
      class="flex justify-center gap-6 text-[10px] font-bold text-dorado uppercase tracking-widest"
    >
      <a href="#" class="hover:text-terracota transition-colors duration-300"
        >Términos</a
      >
      <a href="#" class="hover:text-terracota transition-colors duration-300"
        >Privacidad</a
      >
      <a href="#" class="hover:text-terracota transition-colors duration-300"
        >Políticas</a
      >
    </div>

    <div class="pt-4">
      <span class="text-sm text-terracota"
        >Powered by <a
          href="https://cachemarketing.net"
          class="underline"
          target="_blank">Caché Marketing</a
        >, developed by <a
          href="https://ali-portfolio-blush.vercel.app/"
          class="underline"
          target="_blank">Alí Solórzano</a
        ></span
      >
    </div>
  </div>
</footer>

<style is:global>
  /* Colores personalizados */
  .bg-white {
    background-color: #ffffff;
  }
  .border-beige {
    border-color: #e8dcc8;
  }
  .text-piedra {
    color: #4a4a4a;
  }
  .text-dorado {
    color: #d9c7a3;
  }
  .text-terracota {
    color: #c57a63;
  }
</style>
