---
import { Image } from "astro:assets"
import logo from "../assets/logo.png"

const navLinks = [
  { href: "#espacios", label: "Espacios" },
  { href: "#finanzas", label: "Consultoría Económica" },
  { href: "#testimonios", label: "Testimonios" },
]
---

<header
  class="fixed top-0 w-full z-50 bg-white/70 backdrop-blur-md border-b border-gray-100"
>
  <div
    class="max-w-7xl mx-auto px-6 md:px-10 py-4 flex justify-between items-center"
  >
    <a href="/" class="flex items-center transition-opacity hover:opacity-80">
      <Image
        src={logo}
        alt="Miami Transformation Logo"
        class="w-32 md:w-40 h-auto object-contain"
        loading="eager"
      />
    </a>

    <nav class="hidden md:flex gap-8 text-sm font-medium">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-[#1a1c2e]/80 hover:text-indigo-600 transition-colors duration-200"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <a
      class="bg-[#1a1c2e] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-indigo-900 transition-all shadow-lg shadow-indigo-100/20 active:scale-95"
      href="#contacto"
    >
      Agendar Cita
    </a>
  </div>
</header>
