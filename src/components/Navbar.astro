---
import { Image } from "astro:assets"
import logo from "../assets/logo.png"
---

<header class="fixed top-0 w-full z-50 glass-nav border-b border-beige">
  <div
    class="max-w-7xl mx-auto px-6 md:px-10 py-5 flex justify-between items-center"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center transition-opacity hover:opacity-80">
      <Image
        src={logo}
        alt="Artespazios Logo"
        class="w-24 md:w-32 h-auto object-contain"
        loading="eager"
      />
    </a>

    <!-- Navegación Desktop + Botón CTA centrado como grupo -->
    <div class="hidden lg:flex items-center gap-12">
      <!-- Navegación -->
      <nav class="flex gap-8 text-[10px] font-bold uppercase tracking-widest">
        <a
          href="#metodo"
          class="hover:text-terracota transition-colors duration-300">Método</a
        >
        <a
          href="#servicios"
          class="hover:text-terracota transition-colors duration-300"
          >Servicios</a
        >
        <a
          href="#sobre-mi"
          class="hover:text-terracota transition-colors duration-300"
          >Sobre mí</a
        >
        <a
          href="#faq"
          class="hover:text-terracota transition-colors duration-300">FAQ</a
        >
        <a
          href="#contacto"
          class="hover:text-terracota transition-colors duration-300"
          >Contacto</a
        >
      </nav>

      <!-- Botón CTA (más al centro) -->
      <button
        class="bg-terracota text-white px-7 py-3 rounded-full text-[10px] font-bold uppercase tracking-widest hover:opacity-90 transition shadow-lg shadow-terracota/20"
      >
        Agenda tu diagnóstico
      </button>
    </div>

    <!-- Redes Sociales Desktop (Instagram, TikTok, Facebook) -->
    <div class="hidden lg:flex items-center gap-4">
      <!-- Instagram -->
      <a
        href="https://www.instagram.com/artespazios/"
        class="text-dorado hover:text-terracota transition-colors duration-300"
        aria-label="Instagram"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          class="w-4 h-4"
          fill="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM5.838 12a6.162 6.162 0 1112.324 0 6.162 6.162 0 01-12.324 0zM12 16a4 4 0 110-8 4 4 0 010 8zm4.965-10.405a1.44 1.44 0 112.881.001 1.44 1.44 0 01-2.881-.001z"
          ></path>
        </svg>
      </a>

      <!-- TikTok -->
      <a
        href="https://www.tiktok.com/@artespazios/"
        class="text-dorado hover:text-terracota transition-colors duration-300"
        aria-label="TikTok"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          class="w-4 h-4"
          fill="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"
          ></path>
        </svg>
      </a>

      <!-- Facebook -->
      <a
        href="https://www.facebook.com/share/1CQBsYRah7/?mibextid=wwXIfr"
        class="text-dorado hover:text-terracota transition-colors duration-300"
        aria-label="Facebook"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          class="w-4 h-4"
          fill="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
          ></path>
        </svg>
      </a>
    </div>

    <!-- Botón menú móvil -->
    <button
      class="lg:hidden text-piedra hover:text-terracota transition-colors"
      aria-label="Menú"
      id="menu-btn"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- Menú Móvil (oculto por defecto) -->
  <div
    class="lg:hidden hidden bg-crema/95 backdrop-blur-lg border-t border-beige"
    id="mobile-menu"
  >
    <div class="max-w-7xl mx-auto px-6 py-6 space-y-4">
      <nav
        class="flex flex-col gap-4 text-sm font-bold uppercase tracking-widest"
      >
        <a
          href="#metodo"
          class="hover:text-terracota transition-colors py-2 text-piedra/60"
          >Método</a
        >
        <a
          href="#servicios"
          class="hover:text-terracota transition-colors py-2 text-piedra/60"
          >Servicios</a
        >
        <a
          href="#sobre-mi"
          class="hover:text-terracota transition-colors py-2 text-piedra/60"
          >Sobre mí</a
        >
        <a
          href="#faq"
          class="hover:text-terracota transition-colors py-2 text-piedra/60"
          >FAQ</a
        >
        <a
          href="#contacto"
          class="hover:text-terracota transition-colors py-2 text-piedra/60"
          >Contacto</a
        >
      </nav>

      <!-- Botón CTA Móvil -->
      <a
        href="#contacto"
        class="w-full bg-terracota text-white px-6 py-3 rounded-full text-[10px] font-bold uppercase tracking-widest hover:opacity-90 transition shadow-lg shadow-terracota/20"
      >
        Agenda tu diagnóstico
      </a>

      <!-- Redes Sociales Móvil (Instagram, TikTok, Facebook) -->
      <div class="flex justify-center gap-6 pt-4 border-t border-beige">
        <!-- Instagram -->
        <a
          href="https://www.instagram.com/artespazios/"
          class="text-dorado hover:text-terracota transition-colors"
          aria-label="Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069z"
            ></path>
          </svg>
        </a>

        <!-- TikTok -->
        <a
          href="https://www.tiktok.com/@artespazios/"
          class="text-dorado hover:text-terracota transition-colors"
          aria-label="TikTok"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"
            ></path>
          </svg>
        </a>

        <!-- Facebook -->
        <a
          href="https://www.facebook.com/share/1CQBsYRah7/?mibextid=wwXIfr"
          class="text-dorado hover:text-terracota transition-colors"
          aria-label="Facebook"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Toggle para menú móvil
  const menuBtn = document.getElementById("menu-btn")
  const mobileMenu = document.getElementById("mobile-menu")

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener("click", () => {
      mobileMenu.classList.toggle("hidden")
    })

    // Cerrar menú al hacer clic en un enlace
    const mobileLinks = mobileMenu.querySelectorAll("a")
    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.add("hidden")
      })
    })
  }
</script>

<style is:global>
  /* Estilos del navbar */
  .glass-nav {
    background: rgba(247, 243, 238, 0.9);
    backdrop-filter: blur(12px);
  }

  /* Colores personalizados */
  .border-beige {
    border-color: #e8dcc8;
  }
  .text-piedra {
    color: #4a4a4a;
  }
  .text-terracota {
    color: #c57a63;
  }
  .text-dorado {
    color: #d9c7a3;
  }
  .bg-terracota {
    background-color: #c57a63;
  }
  .bg-crema {
    background-color: #f7f3ee;
  }
  .shadow-terracota\/20 {
    box-shadow: 0 10px 15px -3px rgba(197, 122, 99, 0.2);
  }

  /* Transiciones */
  .transition-colors {
    transition-property: color, background-color, border-color;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 300ms;
  }
</style>
