---
import { Image } from "astro:assets"
import logo from "../assets/logo.png"
---

<header
  class="fixed top-0 w-full z-50 bg-crema/80 backdrop-blur-[10px] border-b border-beige"
>
  <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
    <!-- Logo -->
    <a href="/" class="flex items-center transition-opacity hover:opacity-80">
      <Image
        src={logo}
        alt="Miami Transformation Logo"
        class="w-32 md:w-40 h-auto object-contain"
        loading="eager"
      />
    </a>

    <!-- Navegación Desktop -->
    <nav
      class="hidden md:flex gap-8 text-sm font-semibold uppercase tracking-widest text-piedra/70"
    >
      <a href="#metodo" class="hover:text-terracota transition-colors">Método</a
      >
      <a href="#servicios" class="hover:text-terracota transition-colors"
        >Servicios</a
      >
      <a href="#sobre-mi" class="hover:text-terracota transition-colors"
        >Sobre Mí</a
      >
    </nav>

    <!-- Botón CTA -->
    <a
      href="#contacto"
      class="bg-terracota text-white px-6 py-2.5 rounded-full text-sm font-bold hover:opacity-90 transition-opacity"
    >
      Agenda tu diagnóstico
    </a>
  </div>
</header>
