---
// Servicios.astro con props
export interface ServiceFeature {
  text: string;
}

export interface ServiceSection {
  title: string;
  items: string[];
}

export interface Service {
  title: string;
  description: string;
  buttonText: string;
  buttonLink?: string;
  highlighted?: boolean;
  includes: ServiceSection;
  results: ServiceSection;
  disclaimer?: string;
}

export interface Props {
  id?: string;
  title?: string;
  services?: Service[];
}

const {
  id = "servicios",
  title = "Nuestros Servicios",
  services = [
    {
      title: "Organización de Espacios",
      description: "Transformo tus espacios en sistemas funcionales que reducen carga mental.",
      buttonText: "Solicitar auditoría",
      highlighted: false,
      includes: {
        title: "Incluye",
        items: ["Auditoría funcional", "Diseño de sistemas de orden", "Optimización de flujo"]
      },
      results: {
        title: "Resultados",
        items: ["Menos caos, más claridad", "Decisiones más fáciles"]
      }
    },
    {
      title: "Planificación Económica",
      description: "Estructura técnica para organizar tu vida financiera sin estrés.",
      buttonText: "Solicitar planificación",
      highlighted: true,
      disclaimer: "(No incluye taxes o seguros regulados)",
      includes: {
        title: "Incluye",
        items: ["Organización de documentos", "Estructura de control económico"]
      },
      results: {
        title: "Resultados",
        items: ["Menos incertidumbre", "Estabilidad y claridad total"]
      }
    },
    {
      title: "Bienestar y Ansiedad",
      description: "Acompañamiento práctico para manejar sobrecarga, ansiedad y transición.",
      buttonText: "Agendar sesión",
      highlighted: false,
      includes: {
        title: "Incluye",
        items: ["Sesiones de claridad emocional", "Herramientas de regulación", "Rutinas de estabilidad"]
      },
      results: {
        title: "Resultados",
        items: ["Más calma,","Más enfoque", "Más estabilidad"]
      }
    },
  ]
} = Astro.props;
---

<section id={id} class="py-24 max-w-7xl mx-auto px-6">
  <h2 class="text-4xl font-bold mb-16 text-center text-black/70">{title}</h2>
  
  <div class="space-y-12">
    {services.map((service) => (
      <div class={`flex flex-col md:flex-row rounded-4xl overflow-hidden hover:shadow-xl transition-shadow duration-300 ${
        service.highlighted 
          ? 'bg-piedra text-white' 
          : 'bg-white border border-beige'
      }`}>
        <!-- Columna izquierda - Descripción del servicio -->
        <div class={`md:w-1/3 p-12 ${
          service.highlighted 
            ? 'bg-piedra/90' 
            : 'bg-beige/20'
        }`}>
          <h3 class={`text-2xl font-bold mb-4 ${
            service.highlighted ? 'text-dorado' : 'text-terracota'
          }`}>
            {service.title}
          </h3>
          <p class={`text-sm mb-6 italic ${
            service.highlighted ? 'opacity-80' : 'text-piedra/70'
          }`}>
            {service.description}
          </p>
          <button class={`px-6 py-2 rounded-full text-xs font-bold uppercase hover:opacity-90 transition-opacity ${
            service.highlighted 
              ? 'bg-dorado text-piedra' 
              : 'bg-terracota text-white'
          }`}>
            {service.buttonText}
          </button>
        </div>

        <!-- Columna derecha - Features y resultados -->
        <div class="md:w-2/3 p-12 grid md:grid-cols-2 gap-8">
          <div>
            <h4 class={`font-bold mb-4 uppercase text-[10px] tracking-widest ${
              service.highlighted ? 'text-dorado/50' : 'text-dorado'
            }`}>
              {service.includes.title}
            </h4>
            {service.disclaimer && (
              <p class="text-xs mb-4 opacity-60 italic">{service.disclaimer}</p>
            )}
            <ul class="text-sm space-y-2">
              {service.includes.items.map((item) => (
                <li class="flex items-start gap-2">
                  <span class={service.highlighted ? 'text-dorado' : 'text-terracota'}>•</span>
                  <span class={service.highlighted ? '' : 'text-black/70'}>{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h4 class={`font-bold mb-4 uppercase text-[10px] tracking-widest ${
              service.highlighted ? 'text-dorado/50' : 'text-dorado'
            }`}>
              {service.results.title}
            </h4>
            <ul class="text-sm space-y-2">
              {service.results.items.map((item) => (
                <li class="flex items-start gap-2">
                  <span class={service.highlighted ? 'text-dorado' : 'text-terracota'}>•</span>
                  <span class={service.highlighted ? '' : ''}>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>