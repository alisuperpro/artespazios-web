---
const sectors = [
  "Organización de Espacios",
  "Finanzas & Taxes",
  "Talleres & Bienestar",
]
---

<section id="contacto" class="max-w-7xl mx-auto px-6 md:px-10 py-24 mb-20">
  <div
    class="bg-indigo-50/30 rounded-[45px] p-8 md:p-16 border border-indigo-100 relative overflow-hidden"
  >
    <div
      class="absolute -top-24 -right-24 w-96 h-96 bg-white/50 rounded-full blur-3xl"
    >
    </div>

    <div class="grid lg:grid-cols-2 gap-16 relative z-10">
      <div>
        <h2 class="text-5xl font-bold mb-8 leading-tight tracking-tighter">
          ¿Hablamos sobre <br class="hidden md:block" /> tu caso hoy?
        </h2>
        <p class="text-gray-500 text-lg mb-10 leading-relaxed max-w-md">
          Compártenos tu situación actual y uno de nuestros consultores te
          contactará para guiarte en el camino correcto.
        </p>

        <div class="space-y-6">
          <div class="flex items-center gap-4 group">
            <div
              class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform"
            >
              <span class="text-xl">📍</span>
            </div>
            <p class="font-semibold text-indigo-900">Miami, Florida</p>
          </div>

          <div class="flex items-center gap-4 group">
            <div
              class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform"
            >
              <span class="text-xl">✉️</span>
            </div>
            <p
              class="font-semibold text-indigo-900 underline decoration-indigo-200 underline-offset-4"
            >
              hola@tudominio.com
            </p>
          </div>
        </div>
      </div>

      <form class="space-y-4" onsubmit="event.preventDefault()">
        <div class="grid md:grid-cols-2 gap-4">
          <input
            type="text"
            placeholder="Nombre completo"
            class="w-full px-6 py-4 rounded-2xl bg-white border-transparent shadow-sm focus:ring-2 focus:ring-indigo-400 focus:bg-white outline-none transition-all placeholder:text-gray-400"
          />
          <input
            type="email"
            placeholder="Email"
            class="w-full px-6 py-4 rounded-2xl bg-white border-transparent shadow-sm focus:ring-2 focus:ring-indigo-400 focus:bg-white outline-none transition-all placeholder:text-gray-400"
          />
        </div>

        <select
          class="w-full px-6 py-4 rounded-2xl bg-white border-transparent shadow-sm focus:ring-2 focus:ring-indigo-400 outline-none transition-all text-gray-500 appearance-none cursor-pointer"
        >
          <option disabled selected>Selecciona un sector</option>
          {
            sectors.map((sector) => (
              <option value={sector.toLowerCase().replace(/\s+/g, "-")}>
                {sector}
              </option>
            ))
          }
        </select>

        <textarea
          placeholder="¿Cómo podemos ayudarte?"
          rows="4"
          class="w-full px-6 py-4 rounded-2xl bg-white border-transparent shadow-sm focus:ring-2 focus:ring-indigo-400 outline-none transition-all placeholder:text-gray-400 resize-none"
        ></textarea>

        <button
          class="w-full bg-[#1a1c2e] text-white py-5 rounded-2xl font-bold text-lg hover:bg-indigo-900 transition-all shadow-xl shadow-indigo-100 active:scale-[0.98]"
        >
          Enviar solicitud
        </button>
      </form>
    </div>
  </div>
</section>
