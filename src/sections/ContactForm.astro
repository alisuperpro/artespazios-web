---
// Contacto.astro
// Sección de contacto con formulario para agendar diagnóstico
const sectors = [
  "Organización de Espacios",
  "Planificación Económica",
  "Bienestar y Ansiedad",
]
---

<section id="contacto" class="max-w-7xl mx-auto px-6 md:px-10 py-24 mb-20">
  <div
    class="bg-crema rounded-[45px] p-8 md:p-16 border border-beige relative overflow-hidden shadow-lg"
  >
    <!-- Elemento decorativo de fondo -->
    <div
      class="absolute -top-24 -right-24 w-96 h-96 bg-terracota/5 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute -bottom-24 -left-24 w-96 h-96 bg-dorado/5 rounded-full blur-3xl"
    >
    </div>

    <div class="grid lg:grid-cols-2 gap-16 relative z-10">
      <!-- Columna izquierda - Texto informativo -->
      <div>
        <h2
          class="text-5xl font-bold mb-8 leading-tight tracking-tighter text-piedra"
        >
          ¿Hablamos sobre <br class="hidden md:block" /> tu caso hoy?
        </h2>
        <p class="text-piedra/70 text-lg mb-10 leading-relaxed max-w-md">
          Compártenos tu situación actual y uno de nuestros consultores te
          contactará para guiarte en el camino correcto.
        </p>

        <div class="space-y-6">
          <!-- Ubicación -->
          <div class="flex items-center gap-4 group">
            <div
              class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-md group-hover:scale-110 transition-transform group-hover:shadow-terracota/20"
            >
              <span class="text-xl">📍</span>
            </div>
            <p class="font-semibold text-piedra">Miami, Florida</p>
          </div>

          <!-- Email -->
          <div class="flex items-center gap-4 group">
            <div
              class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-md group-hover:scale-110 transition-transform group-hover:shadow-terracota/20"
            >
              <span class="text-xl">✉️</span>
            </div>
            <a
              href="mailto:hola@artespazios.com"
              class="font-semibold text-terracota underline decoration-dorado underline-offset-4 hover:text-piedra transition-colors"
            >
              hola@artespazios.com
            </a>
          </div>
          <div class="flex items-center gap-4 group">
            <div
              class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-md group-hover:scale-110 transition-transform group-hover:shadow-terracota/20"
            >
              <span class="text-xl">📱</span>
            </div>
            <a
              href="tel:+17864799958"
              class="font-semibold text-terracota underline decoration-dorado underline-offset-4 hover:text-piedra transition-colors"
            >
              +17864799958
            </a>
          </div>
        </div>
      </div>

      <!-- Columna derecha - Formulario -->
      <form class="space-y-4" onsubmit="event.preventDefault()">
        <div class="grid md:grid-cols-2 gap-4">
          <input
            type="text"
            placeholder="Nombre completo"
            class="w-full px-6 py-4 rounded-2xl bg-white border border-beige shadow-sm focus:ring-2 focus:ring-terracota/30 focus:border-terracota focus:bg-white outline-none transition-all placeholder:text-piedra/40 text-piedra"
          />
          <input
            type="email"
            placeholder="Email"
            class="w-full px-6 py-4 rounded-2xl bg-white border border-beige shadow-sm focus:ring-2 focus:ring-terracota/30 focus:border-terracota focus:bg-white outline-none transition-all placeholder:text-piedra/40 text-piedra"
          />
        </div>

        <select
          class="w-full px-6 py-4 rounded-2xl bg-white border border-beige shadow-sm focus:ring-2 focus:ring-terracota/30 focus:border-terracota outline-none transition-all text-piedra/70 appearance-none cursor-pointer hover:border-terracota/30"
        >
          <option disabled selected>Selecciona un servicio</option>
          {
            sectors.map((sector) => (
              <option value={sector.toLowerCase().replace(/\s+/g, "-")}>
                {sector}
              </option>
            ))
          }
        </select>

        <textarea
          placeholder="¿Cómo podemos ayudarte?"
          rows="4"
          class="w-full px-6 py-4 rounded-2xl bg-white border border-beige shadow-sm focus:ring-2 focus:ring-terracota/30 focus:border-terracota outline-none transition-all placeholder:text-piedra/40 text-piedra resize-none"
        ></textarea>

        <button
          class="w-full bg-terracota text-white py-5 rounded-2xl font-bold text-lg hover:bg-piedra transition-all shadow-lg shadow-terracota/20 active:scale-[0.98] hover:shadow-xl"
        >
          Enviar solicitud
        </button>

        <p class="text-[10px] text-piedra/40 text-center mt-4">
          Al enviar aceptas nuestra política de privacidad
        </p>
      </form>
    </div>
  </div>
</section>
