---
const services = [
  {
    title: "Corporativo & Taxes",
    description:
      "Apertura de empresas, corporaciones y gestión de impuestos para individuos y negocios.",
    theme: "light",
  },
  {
    title: "Protección Total",
    description:
      "Seguros de vida, salud y planes funerarios. Planificación financiera familiar.",
    theme: "dark",
  },
]
---

<section id="finanzas" class="bg-[#f8f9ff] py-24 px-6">
  <div class="max-w-7xl mx-auto px-4 md:px-10">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
      <div class="lg:w-1/3">
        <span
          class="text-indigo-600 font-bold uppercase tracking-[0.2em] text-[10px] md:text-xs"
        >
          Sector 02
        </span>
        <h2 class="text-4xl font-bold mt-4 mb-6 leading-tight">
          Planificación Económica y Legal
        </h2>
        <p class="text-gray-500 italic text-lg leading-relaxed">
          "Seguridad financiera para tu familia y tu negocio."
        </p>
      </div>

      <div class="lg:w-2/3 grid md:grid-cols-2 gap-6">
        {
          services.map((service) => (
            <div
              class={`p-8 rounded-[32px] transition-all duration-300 hover:-translate-y-2 shadow-sm ${
                service.theme === "dark"
                  ? "bg-[#1a1c2e] text-white"
                  : "bg-white text-[#1a1c2e] border border-indigo-50"
              }`}
            >
              <h4 class="font-bold text-xl mb-4">{service.title}</h4>
              <p
                class={`text-sm leading-relaxed ${
                  service.theme === "dark" ? "text-gray-400" : "text-gray-500"
                }`}
              >
                {service.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
