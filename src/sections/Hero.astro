---

---

<section class="pt-40 pb-20 px-6">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-12 items-center">
    <!-- Columna izquierda - Contenido textual -->
    <div class="md:w-3/5">
      <h1 class="text-5xl md:text-7xl font-bold mb-8 text-black/70">
        Claridad, orden y bienestar desde tus
        <span class="text-terracota">espacios, procesos y vida</span>
      </h1>
      <p class="text-xl text-piedra/80 mb-10 max-w-xl leading-relaxed">
        Un sistema técnico-emocional que integra organización, planificación y
        bienestar para ayudarte a recuperar control, enfoque y estabilidad.
      </p>
      <div class="flex flex-wrap gap-4">
        <button
          class="bg-terracota text-white px-8 py-4 rounded-full font-bold shadow-lg shadow-terracota/20 hover:opacity-90 transition-opacity"
        >
          Agenda tu diagnóstico inicial
        </button>
        <button
          class="border-2 border-dorado text-terracota px-8 py-4 rounded-full font-bold hover:bg-dorado/10 transition-colors"
        >
          Descarga nuestras guías de claridad
        </button>
      </div>
    </div>

    <!-- Columna derecha - Imagen -->
    <div class="md:w-2/5">
      <div class="bg-white rounded-4xl p-4 shadow-xl border border-beige">
        <img
          src="/images/hero-img.avif"
          class="rounded-4xl w-full h-125 object-cover"
          alt="Espacio ordenado que transmite bienestar y claridad"
        />
      </div>
    </div>
  </div>
</section>
