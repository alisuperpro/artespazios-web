---
// MetodoArtespazios.astro con props
export interface Step {
  number: string
  title: string
  description: string
}

export interface Props {
  id?: string
  title?: string
  subtitle?: string
  steps?: Step[]
}

const {
  id = "metodo",
  title = "El Método Artespazios",
  subtitle = "Un sistema técnico-emocional de 7 pasos.",
  steps = [
    {
      number: "01",
      title: "Ordenar",
      description:
        "Creamos espacio físico, mental y emocional. Reducimos ruido, caos y carga mental.",
    },
    {
      number: "02",
      title: "Clarificar",
      description:
        "Identificamos prioridades, bloqueos y necesidades reales para tomar decisiones claras.",
    },
    {
      number: "03",
      title: "Planificar",
      description:
        "Diseñamos un plan simple, realista y sostenible para avanzar sin sobrecarga",
    },
    {
      number: "04",
      title: "Estructurar",
      description:
        "Estructuramos documentos, responsabilidades y procesos económicos para reducir incertidumbre.",
    },
    {
      number: "05",
      title: "Proteger",
      description:
        "Creamos sistemas de respaldo, prevención y continuidad para tu estabilidad.",
    },
    {
      number: "06",
      title: "Crecer",
      description:
        "Desarrollamos hábitos y rutinas que sostienen tu nueva claridad.",
    },
    {
      number: "07",
      title: "Emprender",
      description:
        "Activamos proyectos, ideas o cambios de vida con estructura y dirección.",
    },
  ],
} = Astro.props
---

<section id={id} class="bg-beige/30 py-24">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Encabezado -->
    <div class="text-center mb-16">
      <h2 class="text-5xl font-bold mb-4 text-black/70">{title}</h2>
      <p class="text-terracota font-medium italic">{subtitle}</p>
    </div>

    <!-- Grid de pasos -->
    <div
      class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-7 gap-4 text-center"
    >
      {
        steps.map((step) => (
          <div class="bg-white p-6 rounded-3xl border border-beige hover:transform hover:-translate-y-1 transition-all duration-300">
            <div class="font-bold text-terracota mb-2 text-2xl">
              {step.number}
            </div>
            <h4 class="font-bold text-xs uppercase mb-2">{step.title}</h4>
            <p class="text-[10px] text-piedra/60">{step.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style is:global>
  .bg-beige\/30 {
    background-color: rgba(232, 220, 200, 0.3);
  }
  .border-beige {
    border-color: #e8dcc8;
  }
  .text-terracota {
    color: #c57a63;
  }
  .text-piedra {
    color: #4a4a4a;
  }
</style>
