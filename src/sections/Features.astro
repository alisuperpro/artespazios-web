---
// QueEsArtespazios.astro con props
export interface Feature {
  icon: string
  title: string
  description: string
  highlighted?: boolean
}

export interface Props {
  subtitle?: string
  title?: string
  features?: Feature[]
}

const {
  subtitle = "¿Qué es Artespazios?",
  title = "Es un sistema integral que combina ingeniería, organización y bienestar emocional para transformar tus decisiones y tu manera de vivir.",
  features = [
    {
      icon: "✦",
      title: "Espacios físicos",
      description:
        "Orden funcional, sistemas sostenibles y ambientes que reducen carga mental.",
      highlighted: false,
    },
    {
      icon: "✦",
      title: "Procesos personales",
      description:
        "Planificación económica, documental y familiar para recuperar control.",
      highlighted: false,
    },
    {
      icon: "✦",
      title: "Bienestar emocional",
      description:
        "Herramientas prácticas para manejar ansiedad, sobrecarga y transición.",
      highlighted: true,
    },
  ],
} = Astro.props
---

<section class="bg-white py-24">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Encabezado -->
    <div class="max-w-3xl mb-16">
      <h2
        class="text-terracota font-bold uppercase tracking-widest text-xs mb-4"
      >
        {subtitle}
      </h2>
      <p class="text-3xl font-medium text-piedra leading-snug">
        {title}
      </p>
    </div>

    <!-- Tarjetas de características -->
    <div class="grid md:grid-cols-3 gap-8">
      {
        features.map((feature) => (
          <div
            class={`p-10 rounded-4xl border border-beige hover:transform hover:-translate-y-1 transition-all duration-300 ${
              feature.highlighted
                ? "bg-terracota text-white"
                : "bg-crema text-piedra"
            }`}
          >
            <div
              class={`text-3xl mb-4 ${feature.highlighted ? "text-white" : "text-terracota"}`}
            >
              {feature.icon}
            </div>
            <h3 class="font-bold text-xl mb-3">{feature.title}</h3>
            <p
              class={`text-sm ${feature.highlighted ? "opacity-90" : "text-piedra/70"}`}
            >
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
