---
const features = [
  "Home Organizing Profesional",
  "Optimización de Espacios de Trabajo",
  "Sistemas de Orden Sostenible",
]
---

<section
  id="espacios"
  class="max-w-7xl mx-auto px-6 md:px-10 py-24 border-t border-gray-100"
>
  <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
    <div class="order-2 md:order-1">
      <span
        class="text-indigo-600 font-bold uppercase tracking-[0.2em] text-[10px] md:text-xs"
      >
        Sector 01
      </span>

      <h2 class="text-4xl md:text-5xl font-bold mt-4 mb-6 leading-tight">
        Organización de <br class="hidden lg:block" /> Espacios Físicos
      </h2>

      <p class="text-gray-500 text-lg mb-8 max-w-lg">
        Estructuramos tu entorno para maximizar la productividad y la paz
        mental, tanto en hogares como en sedes corporativas.
      </p>

      <ul class="space-y-4">
        {
          features.map((item) => (
            <li class="flex items-center gap-3 text-gray-700 font-medium">
              <span class="text-indigo-500 text-lg">✦</span>
              {item}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="order-1 md:order-2">
      <div
        class="bg-gray-100 rounded-[2.5rem] aspect-video md:aspect-square lg:aspect-video overflow-hidden shadow-2xl shadow-indigo-100/50 group"
      >
        <img
          src="https://images.unsplash.com/photo-1494438639946-1ebd1d20bf85?auto=format&fit=crop&q=80&w=800"
          alt="Organización de espacios modernos"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      </div>
    </div>
  </div>
</section>
