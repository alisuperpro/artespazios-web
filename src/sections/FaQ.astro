---
// PreguntasFrecuentes.astro con props
export interface FAQ {
  question: string
  answer: string
}

export interface Props {
  title?: string
  faqs?: FAQ[]
  ctaTitle?: string
  ctaButtonText?: string
  ctaButtonLink?: string
}

const {
  title = "Preguntas Frecuentes",
  faqs = [
    {
      question: "¿Cuánto dura el proceso?",
      answer:
        "Depende del servicio, pero siempre iniciamos con un diagnóstico para definir tiempos.",
    },
    {
      question: "¿Trabajas online?",
      answer:
        "Sí. La mayoría de los procesos pueden realizarse a distancia con éxito.",
    },
  ],
  ctaTitle = "Recupera claridad, orden y bienestar.",
  ctaButtonText = "Agenda tu diagnóstico inicial",
  ctaButtonLink = "#contacto",
} = Astro.props
---

<section class="bg-crema py-24 border-t border-beige" id="faq">
  <div class="max-w-4xl mx-auto px-6">
    <!-- Título -->
    <h2 class="text-3xl font-bold mb-12 text-center italic text-black/70">
      {title}
    </h2>

    <!-- Lista de preguntas -->
    <div class="space-y-6">
      {
        faqs.map((faq) => (
          <div class="bg-white p-6 rounded-2xl border border-beige hover:shadow-md transition-shadow duration-300">
            <p class="font-bold text-terracota mb-2">{faq.question}</p>
            <p class="text-sm text-piedra/70 mt-2 leading-relaxed">
              {faq.answer}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Llamado a la acción final -->
    <div class="mt-24 text-center">
      <h2 class="text-4xl font-bold mb-8 leading-tight text-black/70">
        {ctaTitle}
      </h2>
      <a
        href={ctaButtonLink}
        class="inline-block bg-terracota text-white px-12 py-5 rounded-full font-bold text-lg shadow-xl hover:shadow-2xl hover:scale-105 transition-all duration-300"
      >
        {ctaButtonText}
      </a>
    </div>
  </div>
</section>
